# Origen del API (puerto local o URL pública). Si no termina en /api, el cliente añade /api solo.
# Login final: {VITE_API_URL normalizado}/auth/login  →  .../api/auth/login
#
# Local:
#   VITE_API_URL=http://localhost:3000
# Producción (ej. CloudFront frente al backend):
#   VITE_API_URL=https://dsjggq5txybwy.cloudfront.net
#   o ya con sufijo:
#   VITE_API_URL=https://dsjggq5txybwy.cloudfront.net/api

VITE_API_URL=http://localhost:3000
